# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real keys.

# Supabase — required. Get these from your Supabase project settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Absolute site URL used by layout metadata (OG tags, canonical links, JSON-LD).
# Optional in dev. In prod, set to your public origin with no trailing slash.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
